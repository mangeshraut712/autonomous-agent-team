# Required: Bot token from @BotFather (format: 123456789:ABC...)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Required: Numeric Telegram chat/user ID to receive agent notifications
# Example: 123456789
TELEGRAM_CHAT_TARGET=your_telegram_chat_id_here

# Optional: Parallel Search API key (used by scripts/parallel-search.sh fallback)
# PARALLEL_API_KEY=your_parallel_api_key_here

# Optional: status check interval in seconds (default: 900)
# STATUS_INTERVAL_SECONDS=900
