# ─── .env.example — Copy to .env and fill in your values ────────────────────
# cp .env.example .env
# Never commit .env — it's in .gitignore

# ─── Telegram (Required for Telegram integration) ────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your numeric Telegram user ID (find it via @userinfobot)
TELEGRAM_CHAT_TARGET=your_telegram_user_id_here

# ─── AI Model Providers (pick at least one) ──────────────────────────────────
# Anthropic — Best for complex reasoning + coding (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — Alternative model provider + REQUIRED for semantic memory embeddings
# Memory embeddings use text-embedding-3-small (cheap, fast)
OPENAI_API_KEY=sk-proj-...

# Google Gemini — Alternative model + web search provider
# GEMINI_API_KEY=AIza...

# ─── Web Search (Optional but highly recommended) ────────────────────────────
# OpenClaw auto-detects available providers in this order: Brave → Gemini → Kimi → Perplexity → Grok

# Kimi / Moonshot (recommended — generous free tier)
# KIMI_API_KEY=sk-...
# MOONSHOT_API_KEY=sk-...

# Brave Search
# BRAVE_API_KEY=...

# Perplexity
# PERPLEXITY_API_KEY=pplx-...

# Grok (xAI)
# XAI_API_KEY=xai-...

# Parallel Search (this repo's custom multi-source fallback)
# PARALLEL_API_KEY=...

# ─── OpenClaw Advanced (Optional) ────────────────────────────────────────────
# Force a specific web search provider
# OPENCLAW_WEB_PROVIDER=kimi

# Override the model used for cron jobs
# OPENCLAW_CRON_MODEL=openai-codex/gpt-5.1-codex-mini

# Override gateway connection for scripts
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=

# ─── Notes ────────────────────────────────────────────────────────────────────
# 1. LLM API keys can also go in ~/.openclaw/.env (global for all projects)
# 2. OPENAI_API_KEY is needed even if you use Anthropic as your model — it's
#    used for memory embeddings (text-embedding-3-small, very cheap ~$0.02/1M tokens)
# 3. Run `make env-sync` after editing this file to sync keys into the gateway


# ─── Deployment Defaults (Optional) ─────────────────────────────────────────
# Local gateway port used by scripts/docker-compose
# OPENCLAW_GATEWAY_PORT=18789

# Docker runtime toggles
# OPENCLAW_LOG_LEVEL=info
# OPENCLAW_APM_ENABLED=false

# GitLab live proof helper (optional for contest automation)
# GITLAB_DUO_ENDPOINT=
# GITLAB_DUO_TOKEN=
# GITLAB_BASE_URL=https://gitlab.com
# GITLAB_TOKEN=
# GITLAB_PROJECT_ID=
# GITLAB_MR_IID=
