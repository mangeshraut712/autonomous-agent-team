# Required: Bot token from @BotFather (format: 123456789:ABC...)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Required: Numeric Telegram chat/user ID for notifications.
# Example: 123456789
TELEGRAM_CHAT_TARGET=your_telegram_chat_id_here

# Optional: explicit Telegram user ID allowlist entry (same value as your Telegram user id)
# TELEGRAM_USER_ID=123456789

# Optional: OpenClaw web_search providers (official).
# Auto-detection order in OpenClaw: Brave -> Gemini -> Kimi -> Perplexity -> Grok
# BRAVE_API_KEY=...
# GEMINI_API_KEY=...
# KIMI_API_KEY=...
# MOONSHOT_API_KEY=...
# PERPLEXITY_API_KEY=...
# XAI_API_KEY=...

# Optional: Parallel Search fallback (this repo's custom script).
# PARALLEL_API_KEY=...

# Optional: force provider in OpenClaw config (`brave|gemini|kimi|perplexity|grok`)
# OPENCLAW_WEB_PROVIDER=

# Optional: cron model override for scripts/add-cron-jobs.sh
# OPENCLAW_CRON_MODEL=

# Optional: gateway overrides for CLI calls in scripts
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=
