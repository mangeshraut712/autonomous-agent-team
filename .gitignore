# .gitignore — Autonomous AI Agent Team Workspace

# ─── Secrets & credentials ─────────────────────────────────────────────────
.env
*.env
.env.*
!.env.example

# OpenClaw identity & config
.openclaw/
openclaw.json

# ─── Agent runtime state (personal, never shared) ──────────────────────────
# Daily memory logs are personal runtime state — exclude from commits
agents/*/memory/*.md
agents/*/memory/

# Intel data files (generated at runtime)
intel/data/
intel/DAILY-INTEL.md

# ─── OS files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Temp/build files ──────────────────────────────────────────────────────
*.log
*.tmp
node_modules/
npm-debug.log*
add-cron-jobs.sh

# ─── Editor ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
